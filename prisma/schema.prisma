generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  pin       String
  name      String
  role      Role
  createdAt DateTime @default(now())
}

enum Role {
  OWNER
  EMPLOYEE
}

model Product {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
}

model Batch {
  id        String   @id @default(cuid())
  productId String
  createdAt DateTime @default(now())
}

model Sale {
  id        String   @id @default(cuid())
  employeeId String
  createdAt DateTime @default(now())
}