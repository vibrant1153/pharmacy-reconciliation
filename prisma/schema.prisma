generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  pin       String
  name      String
  role      Role
  createdAt DateTime @default(now())
}

enum Role {
  OWNER
  EMPLOYEE
}

model Product {
  id              String   @id @default(cuid())
  name            String
  pricePerStrip   Decimal  @db.Decimal(10, 2)
  stripsPerCarton Int
  archived        Boolean  @default(false)
  createdAt       DateTime @default(now())
  batches         Batch[]
}

model Batch {
  id              String      @id @default(cuid())
  productId       String
  product         Product     @relation(fields: [productId], references: [id])
  cartonsAdded    Int
  remainingStrips Int
  status          BatchStatus @default(ACTIVE)
  openedAt        DateTime    @default(now())
  closedAt        DateTime?
  createdAt       DateTime    @default(now())
}

enum BatchStatus {
  ACTIVE
  COMPLETED
}

model Sale {
  id        String   @id @default(cuid())
  employeeId String
  createdAt DateTime @default(now())
}