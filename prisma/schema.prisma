generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String     @id @default(cuid())
  username  String     @unique
  pin       String
  name      String
  role      Role
  createdAt DateTime   @default(now())
  sales     Sale[]
  audits    AuditLog[]
}

enum Role {
  OWNER
  EMPLOYEE
}

model Category {
  id            String        @id @default(cuid())
  name          String        @unique
  subcategories Subcategory[]
  products      Product[]
  createdAt     DateTime      @default(now())
}

model Subcategory {
  id         String   @id @default(cuid())
  name       String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  products   Product[]
  createdAt  DateTime @default(now())

  @@unique([name, categoryId])
}

model Product {
  id              String           @id @default(cuid())
  name            String
  archived        Boolean          @default(false)
  categoryId      String?
  category        Category?        @relation(fields: [categoryId], references: [id])
  subcategoryId   String?
  subcategory     Subcategory?     @relation(fields: [subcategoryId], references: [id])
  createdAt       DateTime         @default(now())
  packagingLevels PackagingLevel[]
  batches         Batch[]
}

// Ordered chain per product: order 0 = largest unit (e.g. Box), highest order = base/sellable unit (e.g. Tablet)
model PackagingLevel {
  id               String     @id @default(cuid())
  productId        String
  product          Product    @relation(fields: [productId], references: [id])
  name             String     // "Box", "Strip", "Tablet"
  order            Int        // 0 = top of chain
  quantityInParent Int?       // how many of this = 1 of the level above; null for order 0
  isSellable       Boolean    @default(true)
  isBaseUnit       Boolean    @default(false) // true for the smallest physical unit
  price            Decimal?   @db.Decimal(10, 2) // set only where isSellable = true
  saleItems        SaleItem[]

  @@unique([productId, order])
}

model Batch {
  id                 String      @id @default(cuid())
  productId          String
  product            Product     @relation(fields: [productId], references: [id])
  cartonsAdded       Int         // number of top-level units added (e.g. boxes)
  totalBaseUnits     Int         // total base units (e.g. tablets) this batch represents
  remainingBaseUnits Int
  status             BatchStatus @default(PENDING)
  openedAt           DateTime    @default(now())
  closedAt           DateTime?
  expectedRevenue    Decimal?    @db.Decimal(10, 2)
  createdAt          DateTime    @default(now())
  saleItems          SaleItem[]
}

enum BatchStatus {
  PENDING
  ACTIVE
  COMPLETED
}

model Sale {
  id         String     @id @default(cuid())
  employeeId String
  employee   User       @relation(fields: [employeeId], references: [id])
  createdAt  DateTime   @default(now())
  total      Decimal    @db.Decimal(10, 2)
  voided     Boolean    @default(false)
  items      SaleItem[]
}

model SaleItem {
  id                String         @id @default(cuid())
  saleId            String
  sale              Sale           @relation(fields: [saleId], references: [id])
  batchId           String
  batch             Batch          @relation(fields: [batchId], references: [id])
  productId         String
  packagingLevelId  String
  packagingLevel    PackagingLevel @relation(fields: [packagingLevelId], references: [id])
  quantitySold      Int
  baseUnitsConsumed Int
  pricePerUnit      Decimal        @db.Decimal(10, 2)
  profit            Decimal        @db.Decimal(10, 2)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String
  oldValue  String?
  newValue  String?
  timestamp DateTime @default(now())
}

model DailyReconciliation {
  id         String   @id @default(cuid())
  date       DateTime @unique @db.Date
  actualCash Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
}

model Alert {
  id        String      @id @default(cuid())
  type      AlertType
  productId String?
  batchId   String?
  message   String
  status    AlertStatus @default(OPEN)
  createdAt DateTime    @default(now())
}

enum AlertType {
  LOW_STOCK
  DISCREPANCY
  STALE_ITEM
}

enum AlertStatus {
  OPEN
  DISMISSED
}

model PackagingLevel {
  id               String     @id @default(cuid())
  productId        String
  product          Product    @relation(fields: [productId], references: [id])
  name             String
  order            Int
  quantityInParent Int?
  isSellable       Boolean    @default(true)
  isBaseUnit       Boolean    @default(false)
  price            Decimal?   @db.Decimal(10, 2)
  purchasePrice    Decimal?   @db.Decimal(10, 2)
  saleItems        SaleItem[]

  @@unique([productId, order])
}

